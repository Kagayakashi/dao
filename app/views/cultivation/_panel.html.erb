<section class="cultivation-panel">
  <%= render "shared/media_banner", image_name: "main.png", alt: t("cultivation.panel.banner_alt"), banner_class: "main-banner", image_class: "main-banner__image" %>

  <p class="eyebrow"><%= cultivation_icon(:scroll) %> <%= t(".eyebrow") %></p>
  <h1><%= character.name %></h1>
  <p class="screen-note"><%= t(".screen_note") %></p>

  <% if offline_qi_gained.positive? %>
    <p class="offline-gain"><%= cultivation_icon(:qi) %> <%= t(".offline_gain", qi: number_with_delimiter(offline_qi_gained)) %></p>
  <% end %>

  <% if local_assigns[:completed_spirit_expedition].present? %>
    <p class="offline-gain">
      <%= cultivation_icon(:coin) %>
      <%= t(".spirit_expedition_completed", qi: number_with_delimiter(completed_spirit_expedition[:qi]), wen: number_with_delimiter(completed_spirit_expedition[:wen]), donation_currency: number_with_delimiter(completed_spirit_expedition[:donation_currency])) %>
    </p>
  <% end %>

  <% if character.spirit_expedition_active? %>
    <p class="offline-gain"><%= cultivation_icon(:clock) %> <%= t(".spirit_expedition_active", duration: distance_of_time_in_words(Time.current, character.spirit_expedition_ends_at)) %></p>
  <% end %>

  <% if Current.user.temporary? %>
    <p class="offline-gain">
      <%= link_to new_registration_completion_path, data: { turbo_frame: "_top" } do %>
        <%= cultivation_icon(:key) %> <%= t(".complete_registration_notice", qi: number_with_delimiter(User::COMPLETION_REWARD_QI)) %>
      <% end %>
    </p>
  <% end %>

  <%= tag.div(flash[:notice], class: "form-notice") if flash[:notice] %>

  <% if triggered_event.present? %>
    <div class="event-notice">
      <strong><%= cultivation_icon(:spark) %> <%= triggered_event.localized_title %></strong>
      <span><%= triggered_event.localized_description %></span>
      <% unless triggered_event.qi_delta.zero? %>
        <span><%= triggered_event.qi_delta.positive? ? "+" : "" %><%= t("shared.qi_with_value", qi: number_with_delimiter(triggered_event.qi_delta)) %></span>
      <% end %>
    </div>
  <% end %>

  <div class="realm-card">
    <span class="realm-label"><%= cultivation_icon(:mountain) %> <%= t("shared.realm") %></span>
    <strong><%= character.realm_name %></strong>
    <span><%= t("shared.star", count: character.star) %></span>
    <span><%= t("shared.gear_score_with_value", gear_score: number_with_delimiter(character.gear_score)) %></span>
  </div>

  <div class="qi-progress" aria-label="<%= t(".progress_aria") %>">
    <div class="qi-progress__text">
      <span><%= cultivation_icon(:qi) %> <%= t("shared.qi") %></span>
      <span><%= t(".qi_progress", current: number_with_delimiter(character.qi), required: number_with_delimiter(character.qi_required_for_next_star)) %></span>
    </div>
    <div class="qi-progress__track">
      <div class="qi-progress__fill" style="width: <%= number_to_percentage(character.cultivation_progress * 100, precision: 0) %>"></div>
    </div>
  </div>

  <p class="total-qi"><%= t(".total_qi", qi: number_with_delimiter(character.total_experience)) %></p>
  <% if character.ready_for_breakthrough? %>
    <p class="breakthrough-ready"><%= cultivation_icon(:star) %> <%= t(".breakthrough_ready") %></p>
    <%= button_to t(".breakthrough_button"), cultivation_breakthrough_path, form: { data: { turbo_frame: "_top" } }, class: "ceremonial-button breakthrough-button" %>
  <% else %>
    <p class="next-breakthrough"><%= t(".next_breakthrough", qi: number_with_delimiter(character.qi_until_next_star)) %></p>
  <% end %>

  <div class="realm-card sparring-card">
    <span class="realm-label"><%= cultivation_icon(:sword) %> <%= t("shared.sparring_points") %></span>
    <strong><%= t("shared.sparring_points_count", current: character.sparring_points, max: character.max_sparring_points) %></strong>
    <% if (due_at = character.sparring_recovery_due_at) %>
      <span><%= t("shared.sparring_recovery", duration: distance_of_time_in_words(Time.current, due_at)) %></span>
    <% else %>
      <span><%= t("shared.sparring_recovery_full") %></span>
    <% end %>
  </div>

  <% if character.daily_reward_ready? %>
    <div class="realm-card daily-reward-card">
      <span class="realm-label"><%= cultivation_icon(:spark) %> <%= t("cultivation.panel.daily_reward_heading") %></span>
      <strong><%= t("cultivation.panel.daily_reward_amount", qi: number_with_delimiter(character.daily_reward_qi)) %></strong>
      <span><%= t("cultivation.panel.daily_reward_ready") %></span>
      <%= link_to t("cultivation.panel.daily_reward_link"), temple_path, class: "ceremonial-link", data: { turbo_frame: "_top" } %>
    </div>
  <% end %>

  <% recent_events = character.recent_game_events %>
  <% if recent_events.any? %>
    <section class="events" aria-labelledby="events-heading">
      <h2 id="events-heading"><%= cultivation_icon(:spark) %> <%= t(".events_heading") %></h2>

      <ul class="event-list">
        <% recent_events.each do |event| %>
          <li>
            <strong><%= event.localized_title %></strong>
            <span><%= event.localized_description %></span>
            <% if event.localized_qi_delta.present? %>
              <span><%= event.localized_qi_delta %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
      <div class="section-action">
        <%= link_to t(".events_link"), events_path, class: "ceremonial-link", data: { turbo_frame: "_top" } %>
      </div>
    </section>
  <% end %>

  <nav class="quiet-nav" aria-label="<%= t(".navigation_aria") %>">
    <%= link_to t(".profile_link"), character_path(character), data: { turbo_frame: "_top" } %>
    <%= link_to t(".adventure_link"), adventure_path, data: { turbo_frame: "_top" } %>
  </nav>
</section>
