<section class="cultivation-panel">
  <p class="eyebrow"><%= cultivation_icon(:scroll) %> <%= t(".eyebrow") %></p>
  <h1><%= character.name %></h1>
  <p class="screen-note"><%= t(".screen_note") %></p>

  <% if offline_qi_gained.positive? %>
    <p class="offline-gain"><%= cultivation_icon(:qi) %> <%= t(".offline_gain", qi: number_with_delimiter(offline_qi_gained)) %></p>
  <% end %>

  <%= tag.div(flash[:notice], class: "form-notice") if flash[:notice] %>

  <% if triggered_event.present? %>
    <div class="event-notice">
      <strong><%= cultivation_icon(:spark) %> <%= triggered_event.title %></strong>
      <span><%= triggered_event.description %></span>
      <% unless triggered_event.qi_delta.zero? %>
        <span><%= triggered_event.qi_delta.positive? ? "+" : "" %><%= number_with_delimiter(triggered_event.qi_delta) %> Qi</span>
      <% end %>
    </div>
  <% end %>

  <div class="realm-card">
    <span class="realm-label"><%= cultivation_icon(:mountain) %> <%= t("shared.realm") %></span>
    <strong><%= character.realm_name %></strong>
    <span><%= t("shared.star", count: character.star) %></span>
    <span><%= t("shared.power_with_value", power: number_with_delimiter(character.power)) %></span>
  </div>

  <div class="qi-progress" aria-label="<%= t(".progress_aria") %>">
    <div class="qi-progress__text">
      <span><%= cultivation_icon(:qi) %> <%= t("shared.qi") %></span>
      <span><%= t(".qi_progress", current: number_with_delimiter(character.qi), required: number_with_delimiter(character.qi_required_for_next_star)) %></span>
    </div>
    <div class="qi-progress__track">
      <div class="qi-progress__fill" style="width: <%= number_to_percentage(character.cultivation_progress * 100, precision: 0) %>"></div>
    </div>
  </div>

  <p class="total-qi"><%= t(".total_qi", qi: number_with_delimiter(character.total_experience)) %></p>
  <% if character.ready_for_breakthrough? %>
    <p class="breakthrough-ready"><%= cultivation_icon(:star) %> <%= t(".breakthrough_ready") %></p>
    <%= button_to t(".breakthrough_button"), cultivation_breakthrough_path, form: { data: { turbo_frame: "_top" } }, class: "ceremonial-button breakthrough-button" %>
  <% else %>
    <p class="next-breakthrough"><%= t(".next_breakthrough", qi: number_with_delimiter(character.qi_until_next_star)) %></p>
  <% end %>

  <% achievements = character.earned_achievement_details %>
  <% if achievements.any? %>
    <section class="achievements" aria-labelledby="achievements-heading">
      <h2 id="achievements-heading"><%= cultivation_icon(:trophy) %> <%= t(".achievements_heading") %></h2>

      <ul class="achievement-list">
        <% achievements.each do |achievement| %>
          <li>
            <strong><%= achievement[:name] %></strong>
            <span><%= achievement[:description] %></span>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% recent_events = character.recent_game_events %>
  <% if recent_events.any? %>
    <section class="events" aria-labelledby="events-heading">
      <h2 id="events-heading"><%= cultivation_icon(:spark) %> <%= t(".events_heading") %></h2>

      <ul class="event-list">
        <% recent_events.each do |event| %>
          <li>
            <strong><%= event.title %></strong>
            <span><%= event.description %></span>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <section class="inventory" aria-labelledby="equipment-heading">
    <h2 id="equipment-heading"><%= cultivation_icon(:sword) %> <%= t(".equipment_heading") %></h2>

    <div class="equipment-grid">
      <% InventoryItem::EQUIPMENT_SLOTS.each do |slot| %>
        <% item = character.inventory_items.equipped.find { |equipped_item| equipped_item.equipment_slot == slot } %>
        <div class="inventory-card">
          <span class="inventory-slot"><%= t("inventory_items.slots.#{slot}") %></span>
          <% if item %>
            <strong><%= item.name %></strong>
            <span><%= t("shared.power_bonus", power: number_with_delimiter(item.inventory_power)) %></span>
            <div class="inventory-actions">
              <%= button_to t(".unequip_button"), unequip_inventory_item_path(id: item), class: "small-button" %>
              <%= button_to t(".drop_button"), inventory_item_path(id: item), method: :delete, class: "small-button" %>
            </div>
          <% else %>
            <span><%= t(".empty_slot") %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="inventory" aria-labelledby="inventory-heading">
    <h2 id="inventory-heading"><%= cultivation_icon(:satchel) %> <%= t(".inventory_heading") %></h2>

    <div class="inventory-grid">
      <% inventory_items = character.inventory_items.in_inventory.index_by(&:inventory_slot) %>
      <% 1.upto(Character::INVENTORY_SLOTS) do |slot| %>
        <% item = inventory_items[slot] %>
        <div class="inventory-card">
          <span class="inventory-slot"><%= t(".inventory_slot", slot:) %></span>
          <% if item %>
            <strong><%= item.name %></strong>
            <span><%= t(".inventory_item_summary", kind: t("inventory_items.kinds.#{item.equipment_kind}"), power: number_with_delimiter(item.inventory_power)) %></span>
            <div class="inventory-actions">
              <% if item.equipment_kind == "ring" %>
                <%= button_to t(".equip_button"), equip_inventory_item_path(id: item), class: "small-button" %>
              <% else %>
                <%= button_to t(".equip_button"), equip_inventory_item_path(id: item), class: "small-button" %>
              <% end %>
              <%= button_to t(".drop_button"), inventory_item_path(id: item), method: :delete, class: "small-button" %>
            </div>
          <% else %>
            <span><%= t(".empty_slot") %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <nav class="quiet-nav" aria-label="<%= t(".navigation_aria") %>">
    <%= link_to t(".leaderboard_link"), leaderboard_path, data: { turbo_frame: "_top" } %>
    <%= button_to t(".sign_out_button"), session_path, method: :delete, form: { data: { turbo_frame: "_top" } }, class: "ceremonial-button" %>
  </nav>
</section>
