<% content_for :title, t("characters.show.title", name: @character.name) %>

<main class="cultivation-page">
  <section class="cultivation-panel profile-panel">
    <%= render "shared/media_banner", image_name: @character.profile_image_name, alt: t("characters.show.profile_image_alt", gender: @character.gender_name), banner_class: "profile-banner", image_class: "profile-banner__image" %>

    <p class="eyebrow"><%= cultivation_icon(:mountain) %> <%= t("characters.show.eyebrow") %></p>
    <h1><%= @character.name %></h1>

    <div class="realm-card">
      <span class="realm-label"><%= cultivation_icon(:mountain) %> <%= t("shared.realm") %></span>
      <strong><%= @character.realm_name %></strong>
      <span><%= t("shared.star", count: @character.star) %></span>
      <span><%= t("characters.show.gender", gender: @character.gender_name) %></span>
      <span><%= t("characters.show.gear_score", gear_score: number_with_delimiter(@character.gear_score)) %></span>
      <span><%= t("shared.qi_with_value", qi: number_with_delimiter(@character.total_experience)) %></span>
    </div>

    <section class="combat-stats" aria-labelledby="profile-combat-stats-heading">
      <h2 id="profile-combat-stats-heading"><%= cultivation_icon(:sword) %> <%= t("characters.show.combat_stats_heading") %></h2>

      <dl class="combat-stat-list">
        <% @character.combat_stats.each do |key, value| %>
          <div>
            <dt><%= t("characters.stats.#{key}") %></dt>
            <dd><%= number_with_delimiter(value) %></dd>
          </div>
        <% end %>
      </dl>
    </section>

    <% achievements = @character.earned_achievement_details %>
    <section class="achievements" aria-labelledby="profile-achievements-heading">
      <h2 id="profile-achievements-heading"><%= cultivation_icon(:trophy) %> <%= t("characters.show.achievements_heading") %></h2>

      <% if achievements.any? %>
        <ul class="achievement-list">
          <% achievements.each do |achievement| %>
            <li>
              <strong><%= achievement[:name] %></strong>
              <span><%= achievement[:description] %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-state"><%= t("characters.show.no_achievements") %></p>
      <% end %>
    </section>

    <section class="inventory" aria-labelledby="profile-equipment-heading">
      <h2 id="profile-equipment-heading"><%= cultivation_icon(:sword) %> <%= t("characters.show.equipment_heading") %></h2>

      <div class="equipment-grid">
        <% InventoryItem::EQUIPMENT_SLOTS.each do |slot| %>
          <% item = @character.inventory_items.equipped.find { |equipped_item| equipped_item.equipment_slot == slot } %>
          <div class="inventory-card">
            <span class="inventory-slot"><%= t("inventory_items.slots.#{slot}") %></span>
            <% if item %>
              <strong><%= item.localized_name %></strong>
              <%= render "inventory_items/stat_options", item: %>
            <% else %>
              <span><%= t("characters.show.empty_equipment_slot") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <% if @character != Current.user.character %>
      <div class="sparring-actions">
        <%= button_to t("characters.show.attack_button"), sparring_path(opponent_id: @character.id), class: "ceremonial-button" %>
      </div>
    <% end %>

    <% if @character == Current.user.character %>
      <nav class="quiet-nav" aria-label="<%= t("characters.show.navigation_aria") %>">
        <% if Current.user.temporary? %>
          <%= link_to t("characters.show.complete_registration_link"), new_registration_completion_path %>
        <% end %>
        <%= link_to t("characters.show.inventory_link"), inventory_path %>
      </nav>
    <% end %>
  </section>
</main>
