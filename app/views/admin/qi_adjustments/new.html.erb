<% content_for :title, t("admin.qi_adjustments.new.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel auth-panel">
    <p class="eyebrow"><%= cultivation_icon(:qi) %> <%= t("admin.qi_adjustments.new.eyebrow") %></p>
    <h1><%= t("admin.qi_adjustments.new.heading") %></h1>
    <p class="screen-note"><%= t("admin.qi_adjustments.new.screen_note") %></p>

    <%= tag.div(flash[:alert], class: "form-alert") if flash[:alert] %>
    <%= tag.div(flash[:notice], class: "form-notice") if flash[:notice] %>

    <%= form_with scope: :qi_adjustment, url: admin_qi_adjustment_path, class: "auth-form" do |form| %>
      <%= form.label :character_id, t("admin.qi_adjustments.new.character") %>
      <%= form.select :character_id, character_options %>

      <%= form.label :direction, t("admin.qi_adjustments.new.direction") %>
      <%= form.select :direction, [[ t("admin.qi_adjustments.new.add"), "add" ], [ t("admin.qi_adjustments.new.remove"), "remove" ]] %>

      <%= form.label :amount, t("admin.qi_adjustments.new.amount") %>
      <%= form.number_field :amount, required: true, min: 0, value: 100 %>

      <%= form.submit t("admin.qi_adjustments.new.submit"), class: "ceremonial-button" %>
    <% end %>

    <nav class="quiet-nav" aria-label="<%= t("admin.qi_adjustments.new.navigation_aria") %>">
      <%= link_to t("admin.qi_adjustments.new.admin_link"), admin_root_path %>
      <%= link_to t("admin.qi_adjustments.new.return_link"), root_path %>
    </nav>
  </section>
</main>
