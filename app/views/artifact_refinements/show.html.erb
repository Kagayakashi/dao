<% content_for :title, t("artifact_refinements.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel artifact-refinement-panel">
    <p class="eyebrow"><%= cultivation_icon(:jade) %> <%= t("artifact_refinements.show.eyebrow") %></p>
    <h1><%= t("artifact_refinements.show.heading") %></h1>
    <p class="screen-note"><%= t("artifact_refinements.show.screen_note") %></p>

    <%= tag.div(flash[:alert], class: "form-notice") if flash[:alert] %>
    <%= tag.div(flash[:notice], class: "form-notice") if flash[:notice] %>

    <div class="realm-card">
      <span class="realm-label"><%= cultivation_icon(:coin) %> <%= t("artifact_refinements.show.cost_heading") %></span>
      <strong><%= t("artifact_refinements.show.cost", wen: ArtifactRefinementsController::WEN_COST, liang: ArtifactRefinementsController::LIANG_COST) %></strong>
      <span><%= t("artifact_refinements.show.currency_balance", wen: number_with_delimiter(@character.currency), liang: number_with_delimiter(@character.donation_currency)) %></span>
    </div>

    <% if @items.any? %>
      <section class="inventory" aria-labelledby="artifact-refinement-items-heading">
        <h2 id="artifact-refinement-items-heading"><%= cultivation_icon(:satchel) %> <%= t("artifact_refinements.show.items_heading") %></h2>

        <div class="inventory-grid">
          <% @items.each do |item| %>
            <div class="inventory-card">
              <span class="inventory-slot"><%= item.equipped? ? t("artifact_refinements.show.equipped_location", slot: t("inventory_items.slots.#{item.equipment_slot}")) : t("artifact_refinements.show.inventory_location", slot: item.inventory_slot) %></span>
              <strong><%= item.localized_name %></strong>
              <span><%= t("inventories.show.inventory_item_summary", kind: t("inventory_items.kinds.#{item.equipment_kind}"), power: number_with_delimiter(item.inventory_power)) %></span>
              <div class="inventory-actions">
                <%= button_to t("artifact_refinements.show.reroll_wen_button"), reroll_artifact_refinement_path(item_id: item.id, payment: :wen), class: "small-button" %>
                <%= button_to t("artifact_refinements.show.reroll_liang_button"), reroll_artifact_refinement_path(item_id: item.id, payment: :liang), class: "small-button" %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% else %>
      <p class="empty-state"><%= t("artifact_refinements.show.empty") %></p>
    <% end %>

    <nav class="quiet-nav" aria-label="<%= t("artifact_refinements.show.navigation_aria") %>">
      <%= link_to t("artifact_refinements.show.inventory_link"), inventory_path %>
      <%= link_to t("artifact_refinements.show.adventure_link"), adventure_path %>
    </nav>
  </section>
</main>
