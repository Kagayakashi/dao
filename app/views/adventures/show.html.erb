<% content_for :title, t("adventures.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel adventure-panel">
    <div class="main-banner">
      <%= image_tag "city.png", alt: t("adventures.show.banner_alt"), class: "main-banner__image" %>
    </div>

    <p class="eyebrow"><%= cultivation_icon(:lantern) %> <%= t("adventures.show.eyebrow") %></p>
    <h1><%= t("adventures.show.heading") %></h1>
    <p class="screen-note"><%= t("adventures.show.screen_note") %></p>

    <section class="events" aria-labelledby="adventure-actions-heading">
      <h2 id="adventure-actions-heading"><%= cultivation_icon(:scroll) %> <%= t("adventures.show.actions_heading") %></h2>
      <p class="screen-note"><%= t("adventures.show.temple_note") %></p>
      <%= link_to t("cultivation.panel.daily_reward_link"), temple_path, class: "ceremonial-link adventure-action-link" %>
      <p class="screen-note"><%= t("adventures.show.sparring_note") %></p>
      <%= link_to t("adventures.show.sparring_link"), sparring_path, class: "ceremonial-link adventure-action-link" %>
      <p class="screen-note"><%= t("adventures.show.spirit_expedition_note") %></p>
      <%= link_to t("adventures.show.spirit_expedition_link"), spirit_expedition_path, class: "ceremonial-link adventure-action-link" %>
      <p class="screen-note"><%= t("adventures.show.artifact_refinement_note") %></p>
      <%= link_to t("adventures.show.artifact_refinement_link"), artifact_refinement_path, class: "ceremonial-link adventure-action-link" %>
      <p class="screen-note"><%= t("adventures.show.crier_note") %></p>
      <%= link_to t("adventures.show.crier_link"), news_index_path, class: "ceremonial-link adventure-action-link" %>
    </section>

  </section>
</main>
