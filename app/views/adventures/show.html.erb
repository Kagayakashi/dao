<% content_for :title, t("adventures.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel adventure-panel">
    <%= render "shared/media_banner", image_name: "city.png", alt: t("adventures.show.banner_alt"), banner_class: "main-banner", image_class: "main-banner__image" %>

    <p class="eyebrow"><%= cultivation_icon(:lantern) %> <%= t("adventures.show.eyebrow") %></p>
    <h1><%= t("adventures.show.heading") %></h1>
    <p class="screen-note"><%= t("adventures.show.screen_note") %></p>

    <section class="events" aria-labelledby="adventure-actions-heading">
      <h2 id="adventure-actions-heading"><%= cultivation_icon(:scroll) %> <%= t("adventures.show.actions_heading") %></h2>
      <ul class="action-list">
        <li class="action-card">
          <p><%= t("adventures.show.crier_note") %></p>
          <%= link_to t("adventures.show.crier_link"), news_index_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.temple_note") %></p>
          <%= link_to t("cultivation.panel.daily_reward_link"), temple_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.spirit_expedition_note") %></p>
          <%= link_to t("adventures.show.spirit_expedition_link"), spirit_expedition_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.artifact_refinement_note") %></p>
          <%= link_to t("adventures.show.artifact_refinement_link"), artifact_refinement_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.shop_note") %></p>
          <%= link_to t("adventures.show.shop_link"), shop_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.meridians_note") %></p>
          <%= link_to t("adventures.show.meridians_link"), meridians_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.sect_note") %></p>
          <%= link_to t("adventures.show.sect_link"), sect_path, class: "ceremonial-link" %>
        </li>

        <li class="action-card">
          <p><%= t("adventures.show.sparring_note") %></p>
          <%= link_to t("adventures.show.sparring_link"), sparring_path, class: "ceremonial-link" %>
        </li>

      </ul>
    </section>

  </section>
</main>
