<% content_for :title, t("leaderboards.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel">
    <p class="eyebrow"><%= cultivation_icon(:trophy) %> <%= t(".eyebrow") %></p>
    <h1><%= t(".heading") %></h1>
    <p class="screen-note"><%= t(".screen_note", count: @total_count) %></p>

    <ol class="leaderboard-list">
      <% @characters.each.with_index(@rank_offset + 1) do |character, rank| %>
        <li class="leaderboard-entry">
          <%= link_to character_path(character), class: "leaderboard-entry__link" do %>
            <span class="leaderboard-rank"><%= cultivation_icon(:star) %> <%= rank %></span>
            <span>
              <strong><%= character.name %></strong>
              <small><%= t(".cultivator_summary", realm: character.realm_name, star: t("shared.star", count: character.star)) %></small>
            </span>
            <span class="leaderboard-qi"><%= t("shared.qi_with_value", qi: number_with_delimiter(character.total_experience)) %></span>
            <span class="leaderboard-power"><%= t("shared.gear_score_with_value", gear_score: number_with_delimiter(character.gear_score)) %></span>
          <% end %>
        </li>
      <% end %>
    </ol>

    <nav class="pagination-nav" aria-label="<%= t(".pagination_aria") %>">
      <% if @page > 1 %>
        <%= link_to t(".previous_page"), leaderboard_path(page: @page - 1), class: "ceremonial-link" %>
      <% end %>
      <span><%= t(".page_status", page: @page, total_pages: @total_pages) %></span>
      <% if @page < @total_pages %>
        <%= link_to t(".next_page"), leaderboard_path(page: @page + 1), class: "ceremonial-link" %>
      <% end %>
    </nav>

  </section>
</main>
