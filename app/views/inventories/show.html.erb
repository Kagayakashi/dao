<% content_for :title, t("inventories.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel">
    <p class="eyebrow"><%= cultivation_icon(:satchel) %> <%= t("inventories.show.eyebrow") %></p>
    <h1><%= t("inventories.show.heading") %></h1>
    <p class="screen-note"><%= t("inventories.show.screen_note") %></p>

    <section class="inventory" aria-labelledby="equipment-heading">
      <h2 id="equipment-heading"><%= cultivation_icon(:sword) %> <%= t("inventories.show.equipment_heading") %></h2>

      <div class="equipment-grid">
        <% InventoryItem::EQUIPMENT_SLOTS.each do |slot| %>
          <% item = @character.inventory_items.equipped.find { |equipped_item| equipped_item.equipment_slot == slot } %>
          <div class="inventory-card">
            <span class="inventory-slot"><%= t("inventory_items.slots.#{slot}") %></span>
            <% if item %>
              <strong><%= item.localized_name %></strong>
              <%= render "inventory_items/stat_options", item: %>
              <div class="inventory-actions">
                <%= button_to t("inventories.show.unequip_button"), unequip_inventory_item_path(id: item), class: "small-button" %>
                <%= button_to t("inventories.show.drop_button"), inventory_item_path(id: item), method: :delete, class: "small-button" %>
              </div>
            <% else %>
              <span><%= t("inventories.show.empty_slot") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="inventory" aria-labelledby="inventory-heading">
      <h2 id="inventory-heading"><%= cultivation_icon(:satchel) %> <%= t("inventories.show.inventory_heading") %></h2>
      <p class="total-qi"><%= t("inventories.show.free_slots", count: @character.free_inventory_slot ? Character::INVENTORY_SLOTS - @character.inventory_items.in_inventory.count : 0) %></p>

      <div class="inventory-grid">
        <% inventory_items = @character.inventory_items.in_inventory.index_by(&:inventory_slot) %>
        <% 1.upto(Character::INVENTORY_SLOTS) do |slot| %>
          <% item = inventory_items[slot] %>
          <div class="inventory-card">
            <span class="inventory-slot"><%= t("inventories.show.inventory_slot", slot:) %></span>
            <% if item %>
              <strong><%= item.localized_name %></strong>
              <span><%= t("inventories.show.inventory_item_summary", kind: t("inventory_items.kinds.#{item.equipment_kind}")) %></span>
              <%= render "inventory_items/stat_options", item: %>
              <div class="inventory-actions">
                <%= button_to t("inventories.show.equip_button"), equip_inventory_item_path(id: item), class: "small-button" %>
                <%= button_to t("inventories.show.drop_button"), inventory_item_path(id: item), method: :delete, class: "small-button" %>
              </div>
            <% else %>
              <span><%= t("inventories.show.empty_slot") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <nav class="quiet-nav" aria-label="<%= t("inventories.show.navigation_aria") %>">
      <%= link_to t("inventories.show.profile_link"), character_path(@character) %>
    </nav>
  </section>
</main>
