<% content_for :title, t("users.new.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel auth-panel">
    <p class="eyebrow"><%= cultivation_icon(:mountain) %> <%= t(".eyebrow") %></p>
    <h1><%= t(".heading") %></h1>

    <%= tag.div(flash[:alert], class: "form-alert") if flash[:alert] %>

    <%= form_with model: @user, class: "auth-form" do |form| %>
      <%= form.label :character_name, t(".character_name") %>
      <%= form.text_field :character_name, required: true, maxlength: 40, placeholder: t(".character_name_placeholder") %>

      <%= form.label :character_gender, t(".character_gender") %>
      <%= form.select :character_gender, Character.genders.keys.map { |gender| [ t("characters.genders.#{gender}"), gender ] } %>

      <%= form.submit t(".submit"), class: "ceremonial-button" %>
    <% end %>

    <nav class="quiet-nav" aria-label="<%= t(".navigation_aria") %>">
      <%= link_to t(".sign_in_link"), new_session_path %>
    </nav>
  </section>
</main>
