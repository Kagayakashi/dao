<% content_for :title, t("sparring.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel sparring-panel">
    <%= render "shared/media_banner", image_name: "sparring.png", alt: t("sparring.show.banner_alt"), banner_class: "main-banner", image_class: "main-banner__image" %>

    <p class="eyebrow"><%= cultivation_icon(:sword) %> <%= t("sparring.show.eyebrow") %></p>
    <h1><%= t("sparring.show.heading") %></h1>
    <p class="screen-note"><%= t("sparring.show.screen_note") %></p>

    <%= tag.div(flash[:alert], class: "form-alert") if flash[:alert] %>
    <%= tag.div(flash[:notice], class: "form-notice") if flash[:notice] %>
    <%= tag.div(t("sparring.show.expedition_locked"), class: "form-alert") if @character.spirit_expedition_active? %>

    <div class="realm-card sparring-card">
      <span class="realm-label"><%= cultivation_icon(:sword) %> <%= t("shared.sparring_points") %></span>
      <strong><%= t("shared.sparring_points_count", current: @character.sparring_points, max: @character.max_sparring_points) %></strong>
      <% if (due_at = @character.sparring_recovery_due_at) %>
        <span><%= t("shared.sparring_recovery", duration: distance_of_time_in_words(Time.current, due_at)) %></span>
      <% else %>
        <span><%= t("shared.sparring_recovery_full") %></span>
      <% end %>
    </div>

    <% if params[:result_event_id].present? && (event = @character.game_events.find_by(id: params[:result_event_id])) %>
      <div class="event-notice">
        <strong><%= cultivation_icon(:spark) %> <%= event.localized_title %></strong>
        <span><%= event.localized_description %></span>
        <% if event.localized_qi_delta.present? %>
          <span><%= event.localized_qi_delta %></span>
        <% end %>
        <% if event.metadata["combat_log"].present? %>
          <ol class="combat-log">
            <% event.metadata.fetch("combat_log").each do |entry| %>
              <li>
                <%= t(
                  "sparring.combat_log.#{entry.fetch("result")}",
                  actor: t("sparring.combat_log.actors.#{entry.fetch("actor")}"),
                  damage: number_with_delimiter(entry.fetch("damage"))
                ) %>
              </li>
            <% end %>
          </ol>
        <% end %>
      </div>
    <% end %>

    <% if @opponent.present? %>
      <section class="events" aria-labelledby="sparring-opponent-heading">
        <h2 id="sparring-opponent-heading"><%= cultivation_icon(:mountain) %> <%= t("sparring.show.opponent_heading") %></h2>
        <div class="sparring-matchup">
          <div class="sparring-matchup__names">
            <strong><%= @character.name %></strong>
            <span><%= t("sparring.show.versus") %></span>
            <strong><%= @opponent.name %></strong>
          </div>

          <table class="sparring-stat-table">
            <caption class="visually-hidden"><%= t("sparring.show.stats_table_caption") %></caption>
            <tbody>
              <% [
                [ :damage, number_with_delimiter(@character.damage), number_with_delimiter(@opponent.damage) ],
                [ :defense, number_with_delimiter(@character.defense), number_with_delimiter(@opponent.defense) ],
                [ :evasion, number_with_delimiter(@character.evasion), number_with_delimiter(@opponent.evasion) ],
                [ :accuracy, number_with_delimiter(@character.accuracy), number_with_delimiter(@opponent.accuracy) ],
                [ :critical_rate, number_to_percentage(@character.critical_rate, precision: 1), number_to_percentage(@opponent.critical_rate, precision: 1) ],
                [ :gear_score, number_with_delimiter(@character.gear_score), number_with_delimiter(@opponent.gear_score) ]
              ].each do |stat_key, character_value, opponent_value| %>
                <tr>
                  <td><%= character_value %></td>
                  <th scope="row"><%= t("sparring.stats_short.#{stat_key}") %></th>
                  <td><%= opponent_value %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="sparring-actions">
          <%= button_to t("sparring.show.spare_button"), sparring_path, class: "ceremonial-button", disabled: @character.spirit_expedition_active? %>
          <%= button_to t("sparring.show.change_opponent_button"), change_opponent_sparring_path, class: "ceremonial-button", disabled: @character.spirit_expedition_active? %>
        </div>
      </section>
    <% else %>
      <p class="empty-state"><%= t("sparring.show.no_opponent") %></p>
    <% end %>

    <nav class="quiet-nav" aria-label="<%= t("sparring.show.navigation_aria") %>">
      <%= link_to t("sparring.show.adventure_link"), adventure_path %>
    </nav>
  </section>
</main>
