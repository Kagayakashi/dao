<% content_for :title, t("spirit_expeditions.show.title") %>

<main class="cultivation-page">
  <section class="cultivation-panel adventure-panel">
    <%= render "shared/media_banner", alt: "", image_name: "expedition.png", banner_class: "main-banner", image_class: "main-banner__image" %>

    <p class="eyebrow"><%= cultivation_icon(:jade) %> <%= t("spirit_expeditions.show.eyebrow") %></p>
    <h1><%= t("spirit_expeditions.show.heading") %></h1>
    <p class="screen-note"><%= t("spirit_expeditions.show.screen_note") %></p>

    <%= tag.div(flash[:notice], class: "form-notice") if flash[:notice] %>
    <%= tag.div(flash[:alert], class: "form-alert") if flash[:alert] %>

    <% if @completed_spirit_expedition.present? %>
      <p class="offline-gain">
        <%= cultivation_icon(:coin) %>
        <%= t("spirit_expeditions.show.completed", qi: resource_amount_with_bonus(base: @completed_spirit_expedition[:base_qi], bonus: @completed_spirit_expedition[:qi_bonus]), wen: resource_amount_with_bonus(base: @completed_spirit_expedition[:base_wen], bonus: @completed_spirit_expedition[:wen_bonus]), donation_currency: number_with_delimiter(@completed_spirit_expedition[:donation_currency])) %>
      </p>
    <% end %>

    <% if @character.spirit_expedition_active? %>
      <div class="realm-card">
        <span class="realm-label"><%= cultivation_icon(:clock) %> <%= t("spirit_expeditions.show.active_heading") %></span>
        <strong><%= t("spirit_expeditions.show.active_duration", hours: @character.spirit_expedition_duration_hours) %></strong>
        <span><%= t("spirit_expeditions.show.active_remaining", duration: distance_of_time_in_words(Time.current, @character.spirit_expedition_ends_at)) %></span>
        <%= button_to t("spirit_expeditions.show.complete_now_button", cost: @character.spirit_expedition_instant_completion_cost), complete_spirit_expedition_path, class: "ceremonial-button", disabled: @character.donation_currency < @character.spirit_expedition_instant_completion_cost %>
        <% if @character.donation_currency < @character.spirit_expedition_instant_completion_cost %>
          <span><%= t("spirit_expeditions.show.complete_now_unavailable") %></span>
        <% end %>
      </div>
    <% else %>
      <section class="events" aria-labelledby="spirit-expedition-options-heading">
        <h2 id="spirit-expedition-options-heading"><%= cultivation_icon(:scroll) %> <%= t("spirit_expeditions.show.options_heading") %></h2>

        <div class="activity-options">
          <% @character.spirit_expedition_durations.each do |hours| %>
            <% qi_reward = @character.spirit_expedition_qi_reward_breakdown(hours) %>
            <% min_wen = @character.spirit_expedition_wen_reward_breakdown(hours, @character.spirit_expedition_wen_reward_range.min) %>
            <% max_wen = @character.spirit_expedition_wen_reward_breakdown(hours, @character.spirit_expedition_wen_reward_range.max) %>

            <div class="realm-card activity-option-card">
              <span class="realm-label"><%= t("spirit_expeditions.show.duration", hours:) %></span>
              <strong><%= t("spirit_expeditions.show.qi_reward", qi: resource_amount_with_bonus(base: qi_reward[:base], bonus: qi_reward[:bonus])) %></strong>
              <span><%= t("spirit_expeditions.show.wen_reward", min: resource_amount_with_bonus(base: min_wen[:base], bonus: min_wen[:bonus]), max: resource_amount_with_bonus(base: max_wen[:base], bonus: max_wen[:bonus])) %></span>
              <% if hours == 1 %>
                <span><%= t("spirit_expeditions.show.donation_currency_chance") %></span>
              <% end %>
              <% if hours > 1 %>
                <span><%= t("spirit_expeditions.show.reduced_reward_note") %></span>
              <% end %>
              <%= button_to t("spirit_expeditions.show.start_button"), spirit_expedition_path, params: { hours: }, class: "ceremonial-button" %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <nav class="quiet-nav" aria-label="<%= t("spirit_expeditions.show.navigation_aria") %>">
      <%= link_to t("spirit_expeditions.show.return_link"), adventure_path %>
    </nav>
  </section>
</main>
